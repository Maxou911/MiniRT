# Plusieurs lumières > OK
A 0.25 255,255,255
C 0,1,-2 0,0,1 70

# Spots
L 2,3,-2 0.6 255,255,255          # blanc principal (avant droite)
L -3,4,-1 0.4 255,200,200         # chaud secondaire (avant gauche)
L 0,6,3 0.5 180,200,255           # froid depuis le haut
L 4,1,2 0.3 255,220,120           # chaud latéral droit

# Sol
pl 0,-1,0 0,1,0 200,200,200

# Objets
sp 0,0,3 2 10,0,255               # sphère bleue centrale
sp -2,0,4 1.2 0,255,120           # sphère vert/jaune à gauche
cy 2,0,4 0,1,0 1 3 255,180,80     # cylindre orange à droite